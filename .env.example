# ── Proxmox Connection ──
PVE_HOST=192.168.1.100
PVE_PORT=8006
PVE_NODE=pve

# Auth: API Token (recommended)
PVE_AUTH_METHOD=token
PVE_TOKEN_ID=wallboard@pve!wallboard
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Auth: Password (alternative)
# PVE_AUTH_METHOD=password
# PVE_USER=root@pam
# PVE_PASS=yourpassword

# ── Wallboard Settings ──
NEXT_PUBLIC_TITLE=Proxmox Wallboard
NEXT_PUBLIC_POLL_INTERVAL=10
NEXT_PUBLIC_ROTATE_INTERVAL=8

# Allow self-signed certs from Proxmox
NODE_TLS_REJECT_UNAUTHORIZED=0
